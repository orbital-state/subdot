{
    "name": "subdot",
    "version": "0.1.0",
    "type": "module",
    "bin": {
        "subdot": "./dist/index.js"
    },
    "scripts": {
        "build": "tsc",
        "start": "tsx src/index.ts",
        "dev": "tsx watch src/index.ts",
        "node": "node dist/index.js",
        "clean": "rm -rf dist",
        "prepare": "[ -z \"$NO_PREBUILD\" ] && npm run build || echo 'Skipping build due to NO_PREBUILD'",
        "test": "vitest",
        "lint": "eslint .",
        "format": "prettier --write ."
    },
    "dependencies": {
        "@polkadot/api": "^15.9.1",
        "chevrotain": "^11.0.3",
        "commander": "^11.0.0",
        "ink": "^4.3.1",
        "jsonata": "^2.0.6",
        "nats": "^2.29.3",
        "react": "^18.2.0",
        "toml": "^3.0.0",
        "winston": "^3.17.0",
        "ws": "^8.13.0"
    },
    "devDependencies": {
        "@types/react": "^19.1.0",
        "c8": "^10.1.3",
        "eslint": "^8.0.0",
        "ts-node": "^10.9.1",
        "ts-node-dev": "^2.0.0",
        "tsx": "^4.19.3",
        "typescript": "^5.8.3",
        "vitest": "^3.1.2"
    }
}
